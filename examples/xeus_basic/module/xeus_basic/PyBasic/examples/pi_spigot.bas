100 REM PI SPIGOT ALGORITHM
110 INPUT "How many digits?: ";N
120 L=INT(10*N/3)+1
130 DIM A(300)
140 FOR I=1 TO L
150 A(I)=2
160 NEXT I
170 FOR J=1 TO N
180 Q=0
190 FOR I=L TO 1 STEP -1
200 X=10*A(I)+Q*I
210 D=2*I-1
220 A(I)=X-D*INT(X/D)
230 Q=INT(X/D)
240 NEXT I
250 A(1)=Q-10*INT(Q/10)
260 PRINT STR$(INT(Q/10));
270 IF J=1 THEN PRINT ".";
280 NEXT J
290 PRINT
300 END

